# Copy to .env and fill in. .env is gitignored; this template is committed.

# ---- Database ----------------------------------------------------------
# Unset MONGODB_URI to use the disk-backed embedded MongoDB (dev). For
# production point this at a managed MongoDB (Atlas).
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/industrial_edge
MONGO_DB_PATH=./.mongo-data

# ---- Server ------------------------------------------------------------
PORT=4000
NODE_ENV=development
# CORS_ORIGIN=https://shop.example.com

# ---- Auth (REQUIRED in production) ------------------------------------
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
ADMIN_EMAIL=admin@industrialedge.local
ADMIN_PASSWORD=
ADMIN_NAME=Site Owner

# ---- Payment providers -------------------------------------------------
# Leave blank until you have live merchant credentials. Any provider missing
# a value reports status NOT_CONFIGURED and CANNOT process or verify payments —
# no order can be marked PAID without a real, signature-verified callback.

HBL_MERCHANT_ID=
HBL_API_KEY=
HBL_SECRET=

JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

EASYPAISA_MERCHANT_ID=
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=

# ---- Company / brand (surfaced on storefront + footer) -----------------
# All optional — sensible defaults apply. Override per deployment.
COMPANY_NAME=Industrial Edge
COMPANY_LEGAL_NAME=Industrial Edge Ltd
COMPANY_EMAIL=trade@industrialedge.local
COMPANY_PHONE=+1 (800) 555-0148
COMPANY_ADDRESS1=Unit 7, Forge Park
COMPANY_ADDRESS2=Sheffield Industrial Estate
COMPANY_HOURS=MON–FRI 07:00–18:00
COMPANY_FOUNDED=1998
COMPANY_REGION=

# ---- Currency (also set VITE_CURRENCY / VITE_CURRENCY_LOCALE for the UI) -
CURRENCY=USD
CURRENCY_LOCALE=en-US

# ---- Shipping rates (business config; applied by the order engine) ------
SHIP_FREE_THRESHOLD=250
SHIP_STANDARD_RATE=18
SHIP_EXPRESS_RATE=39

# ---- Marketing claims shown on the hero (not computable) ---------------
MARKETING_CUTOFF=16:00
MARKETING_FULFILMENT_RATE=99.2%

# ---- Engineering constants (defaults are fine; override if needed) ------
TOKEN_TTL_SECONDS=7200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
PRODUCT_SEARCH_MAX=100
ORDERS_LIST_MAX=200
LOW_STOCK_THRESHOLD=100
